# Copy to .streamlit/secrets.toml for local dev.
# In Streamlit Community Cloud, paste the same content into the app's "Secrets" UI
# (Settings -> Secrets). NEVER commit the real file — it is in .gitignore.

# ---- Google OAuth (st.login) ----
# 1. Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
#    Application type: Web application
#    Authorized redirect URIs:
#      http://localhost:8501/oauth2callback        (local dev)
#      https://<your-app>.streamlit.app/oauth2callback   (deployed)
# 2. Paste client_id, client_secret below.
# 3. cookie_secret: any 32+ char random string. Generate with:
#       python -c "import secrets; print(secrets.token_hex(32))"
#
# IMPORTANT: per-provider credentials live in a NESTED table [auth.google],
# not flat under [auth]. Streamlit's st.login("google") looks under that key.
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "REPLACE_WITH_RANDOM_64_CHAR_HEX"

[auth.google]
client_id = "REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "REPLACE_WITH_GOOGLE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ---- AWS / DynamoDB ----
# IAM user created with infrastructure/iam_policy.json (least privilege).
# Region: ap-southeast-1 (Singapore — closest to MY).
[aws]
region = "ap-southeast-1"
access_key_id = "REPLACE_WITH_IAM_ACCESS_KEY_ID"
secret_access_key = "REPLACE_WITH_IAM_SECRET_ACCESS_KEY"

# Optional: backups bucket. Leave empty to disable S3 backups in CI.
[backup]
s3_bucket = "htpn-roster-backups"

# ---- App config ----
[app]
# Set to true to FORCE-disable bootstrap mode (e.g. after first admin claimed).
# Normally leave false — the app auto-locks the door once an admin row exists.
disable_bootstrap = false

# Leave-cap policy. Per requirement: each HO cannot have more than 10 EL/MC.
leave_cap = 10
leave_warn_at = 8

# Minimum staff per ward per day (used for coverage warnings on the dashboard).
# Edit per-ward overrides in the Master Data admin page after deploy.
default_min_staff_per_ward = 1
