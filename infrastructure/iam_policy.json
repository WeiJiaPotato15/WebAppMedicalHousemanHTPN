{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBAppData",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:*:*:table/hkj_roster",
        "arn:aws:dynamodb:*:*:table/hkj_officers",
        "arn:aws:dynamodb:*:*:table/hkj_shifts",
        "arn:aws:dynamodb:*:*:table/hkj_admins",
        "arn:aws:dynamodb:*:*:table/hkj_audit"
      ]
    },
    {
      "Sid": "S3Backups",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::hkj-roster-backups",
        "arn:aws:s3:::hkj-roster-backups/*"
      ]
    }
  ]
}
